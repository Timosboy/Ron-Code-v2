# ─── OpenAI ──────────────────────────────────────────────────────
# Reemplaza con tu propia clave para activar el Agente Abogado de IA real
OPENAI_API_KEY=tu_api_key_de_openai_aqui

# ─── Google Maps (frontend — prefijo VITE_ requerido por Vite) ───
VITE_GOOGLE_MAPS_API_KEY=tu_api_key_de_google_maps_aqui

# Cloudflare R2 — almacenamiento de panorámicas 360 (backend)
# Cuenta: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=tu_account_id
R2_ACCESS_KEY_ID=tu_access_key_id
R2_SECRET_ACCESS_KEY=tu_secret_access_key
R2_BUCKET_NAME=proptech-panoramas
# URL pública del bucket (R2 public bucket o custom domain, sin barra final)
R2_PUBLIC_BASE_URL=https://pub-d163dc78753e497ba3ec1c9dd5c3731f.r2.dev
# ─── Meta (Facebook + Instagram) ─────────────────────────────────
# PAGE ACCESS TOKEN: token de larga duración de tu Página de Facebook.
# Sirve también para postear en Instagram si la cuenta IG está enlazada a la página.
META_ACCESS_TOKEN=tu_page_access_token_aqui

# ID numérico de tu Página de Facebook (ej: 123456789012345)
META_PAGE_ID=tu_facebook_page_id_aqui

# ID numérico de tu cuenta de Instagram Business (ej: 987654321098765)
# Solo necesario si quieres publicar en Instagram directamente.
META_IG_USER_ID=tu_instagram_user_id_aqui

# URL pública de imagen por defecto para los posts (obligatoria para Instagram).
# Debe ser accesible desde internet (no localhost). Usa una imagen de una propiedad demo.
# Ejemplo: https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=1080
META_DEFAULT_IMAGE_URL=https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=1080
